# AI
GROQ_API_KEY=your_groq_api_key_here

# Database
# Railway with persistent volume: sqlite:////data/kccsmartinfox.db
# Railway PostgreSQL add-on: postgresql://...
DATABASE_URL=sqlite:///./kccsmartinfox.db

# Email (Gmail SMTP — use an App Password, not your real password)
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password

# Security — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_to_a_random_secret

# Your deployed Railway URL (set after first deploy)
APP_URL=https://your-app.up.railway.app

# CORS — your Railway URL (same as APP_URL for single-service deploy)
ALLOWED_ORIGINS=https://your-app.up.railway.app
